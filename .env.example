# .env.example — 환경변수 견본 (커밋 O)
# 사용법: 이 파일을 .env로 복사한 뒤 각자의 실제 값으로 채운다.
#   cp .env.example .env
# .env는 .gitignore 처리되어 커밋되지 않는다. spring-dotenv가 실행 시 자동 로드한다.

# --- OAuth2 소셜 로그인 시크릿 (각자 개발자 콘솔에서 발급) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# --- JWT 서명 키 (openssl rand -base64 64 로 생성한 긴 랜덤 문자열) ---
JWT_SECRET=

# --- (선택) JWT 만료 시간 ms — 미설정 시 application.yml 기본값 사용 ---
# JWT_ACCESS_EXPIRE_MS=1800000
# JWT_REFRESH_EXPIRE_MS=1209600000

# --- (선택) Redis 접속 — 미설정 시 localhost:6379 ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- (선택) 로그인 성공 후 프론트 리다이렉트 주소 ---
OAUTH2_REDIRECT_URI=http://localhost:3000/oauth/callback
